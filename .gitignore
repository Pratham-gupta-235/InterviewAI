# Dependency directory
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.*
!.env.example

# Build output
dist/
build/
out/

# Coverage directory
coverage/

# OS generated files
.DS_Store
Thumbs.db

# IDE / Editor folders
.vscode/
.idea/
*.swp
*.swo

# Optional npm cache directory
.npm/

# Optional eslint cache
.eslintcache

# Temporary files
tmp/
temp/

# Node REPL history
.node_repl_history

# Parcel cache (if ever used)
.cache/

# TypeScript (if you later add it)
*.tsbuildinfo